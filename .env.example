PARSER_HOST=localhost
PARSER_PORT=5050
VEHICLE_ID=ghost-vehicle-01
SEND_INTERVAL_MS=5000

# San Francisco Bay Area (default)
LATITUDE=37.7749
LONGITUDE=-122.4194

# Reconnect test mode — sends PACKETS_PER_SESSION packets, force-closes, reconnects, sends again, then exits
RECONNECT_TEST=false
PACKETS_PER_SESSION=5